# Puddle Voice Interviewer Agent — environment configuration.
#
# Copy this file to `.env` and fill in real values:  cp .env.example .env
# `.env` is gitignored; this template (`.env.example`) is committed.

# ─── LLM / VLM providers ──────────────────────────────────────────────
# Anthropic — Live Rubric Scorer, Probe Generator, offline calibration.
ANTHROPIC_API_KEY=

# Google Gemini — Video Perception VLM (non-scoring integrity signals).
# Read by the google-genai SDK when a live Gemini client is constructed.
GEMINI_API_KEY=

# ─── Voice I/O providers ──────────────────────────────────────────────
# Deepgram — streaming speech-to-text (Nova-3).
DEEPGRAM_API_KEY=

# Cartesia — low-latency text-to-speech (Sonic-3).
CARTESIA_API_KEY=

# ─── LiveKit ──────────────────────────────────────────────────────────
# LiveKit Cloud — SFU room provisioning and agent worker dispatch.
# LIVEKIT_URL is the wss:// host; the API key/secret are from the project.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Candidate reconnect grace after a network drop. The agent keeps the room I/O
# open for this many seconds before ending the interview.
PUDDLE_PARTICIPANT_RECONNECT_GRACE_SECONDS=300

# ─── Database ─────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. the Supabase pooled connection URI).
# Used by the backend pg pool and the `pnpm migrate` runner.
DATABASE_URL=

# AWS RDS/ECS alternative to DATABASE_URL. If DATABASE_URL is unset, the
# backend can build its pg config from these split values.
# DATABASE_HOST=
# DATABASE_PORT=5432
# DATABASE_NAME=puddle
# DATABASE_USER=puddle_app
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# ─── Backend server ───────────────────────────────────────────────────
# Host and port for the Fastify Scheduler/API server (backend/src/server.ts).
HOST=0.0.0.0
PORT=8080

# Shared bearer token required for platform-to-backend internal calls when set.
PUDDLE_BACKEND_INTERNAL_TOKEN=

# ─── Optional model / tuning overrides ────────────────────────────────
# Defaults live in agent/src/agent/config.py — uncomment to override.
# PUDDLE_SCORER_MODEL=claude-opus-4-7
# PUDDLE_PROBE_MODEL=claude-opus-4-7
# PUDDLE_VLM_MODEL=gemini-2.5-flash
# PUDDLE_CONFIDENCE_THRESHOLD=0.75

# ─── Object storage ───────────────────────────────────────────────────
# Recording/dashboard persistence is opt-in. Keep this false for the base
# platform/interview deploy until S3 egress and artifact tables are ready.
PUDDLE_RECORDINGS_ENABLED=false

# Media and artifacts use the S3-style layout in backend/src/storage/layout.ts.
PUDDLE_ARTIFACTS_BUCKET=
PUDDLE_ARTIFACTS_REGION=

# When PUDDLE_RECORDINGS_ENABLED=true, LiveKit Cloud Egress uploads directly to
# S3 using least-privilege upload credentials. CDK stores these in Secrets
# Manager for deployed backend tasks.
PUDDLE_EGRESS_S3_ACCESS_KEY_ID=
PUDDLE_EGRESS_S3_SECRET_ACCESS_KEY=
# PUDDLE_EGRESS_S3_SESSION_TOKEN=
#
# Optional. LiveKit Cloud exposes direct AWS AssumeRole for S3 egress on higher
# plans; keep these unset unless LiveKit has enabled/confirmed it for the org.
# PUDDLE_EGRESS_S3_ASSUME_ROLE_ARN=
# PUDDLE_EGRESS_S3_ASSUME_ROLE_EXTERNAL_ID=
# PUDDLE_EGRESS_S3_ENDPOINT=
# PUDDLE_EGRESS_S3_FORCE_PATH_STYLE=false

# Optional per-egress webhook URL. In production this should usually be:
# https://app.usepuddle.com/api/livekit/webhook
PUDDLE_LIVEKIT_WEBHOOK_URL=
