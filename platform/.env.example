# Puddle Platform - local environment configuration.
#
# Copy to `.env.local` for the Next.js platform app.

# WorkOS AuthKit
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://localhost:3000/callback
PUDDLE_ALLOWED_AUTH_DOMAINS=usepuddle.com,workweave.ai
PUDDLE_ASHBY_ONBOARDING_ADMIN_EMAILS=
PUDDLE_TEAM_INVITE_EXPIRY_DAYS=7

# Public URL used for redirects, site links, and generated Ashby webhook URLs.
PUDDLE_WORKOS_REDIRECT_URI=http://localhost:3000/callback
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform-to-backend API calls, including Ashby onboarding, scoring, and interview invites.
PUDDLE_BACKEND_BASE_URL=http://localhost:8080
PUDDLE_BACKEND_INTERNAL_TOKEN=
PUDDLE_DEFAULT_SCRIPT_VERSION=pilot-v1
