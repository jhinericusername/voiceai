{
  "name": "@puddle/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --env-file=../.env.local --import tsx src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "migrate": "node --env-file=../.env.local --import tsx src/db/migrate.ts",
    "migrate:prod": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.0.0",
    "livekit-server-sdk": "^2.7.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
