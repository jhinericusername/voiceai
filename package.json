{
  "name": "puddle-voiceai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "AWS_PROFILE=default corepack pnpm@9.12.0 dev:connected",
    "dev:backend": "corepack pnpm@9.12.0 --filter @puddle/backend dev",
    "dev:connected": "node scripts/dev/dev-connected.mjs",
    "dev:backend:connected": "node scripts/dev/dev-backend-connected.mjs",
    "dev:platform": "corepack pnpm@9.12.0 --filter @puddle/platform dev",
    "historical-fireflies:metadata-backfill:connected": "node scripts/dev/historical-fireflies-metadata-backfill-connected.mjs",
    "grading:evaluate:connected": "node scripts/dev/grading-evaluate-connected.mjs",
    "migrate:backend": "corepack pnpm@9.12.0 --filter @puddle/backend migrate",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:connected-dev": "node --test scripts/dev/connected-dev.test.mjs",
    "test:workos": "node --test scripts/workos/*.test.mjs",
    "workos": "node scripts/workos/workos-admin.mjs",
    "workos:doctor": "node scripts/workos/workos-admin.mjs doctor",
    "workos:orgs": "node scripts/workos/workos-admin.mjs orgs",
    "workos:permissions": "node scripts/workos/workos-admin.mjs permissions",
    "workos:roles": "node scripts/workos/workos-admin.mjs roles"
  }
}
